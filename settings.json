{
  "// 说明": "Claude Code 工作流配置 - 使用相对路径，可复制到任意项目",

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-requirements.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-file-boundary.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-workflow-step.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-bash-boundary.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/error-detector.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/code-review.sh"
          }
        ]
      }
    ]
  }
}
